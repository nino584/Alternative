PORT=3001
NODE_ENV=development

# Generate strong random secrets (minimum 32 chars):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=generate-a-strong-random-secret-here
JWT_REFRESH_SECRET=generate-another-strong-random-secret-here

# CORS origins (comma-separated for multiple frontends)
# Development:
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
# Production (use HTTPS!):
# CORS_ORIGIN=https://alternative.ge,https://admin.alternative.ge

# Public site URL (used for sitemap generation)
# SITE_URL=https://alternative.ge

# ── SSL / HTTPS Configuration ──────────────────────────────────────────────
# The server enforces HTTPS via x-forwarded-proto header in production.
# SSL termination is handled by your reverse proxy or hosting provider.
#
# ── Vercel / Netlify (frontend) ──
#   SSL is automatic. No extra config needed.
#
# ── Railway / Render (server) ──
#   SSL is automatic on *.up.railway.app / *.onrender.com domains.
#   For custom domains: add domain in dashboard → SSL cert auto-provisioned.
#
# ── VPS with Nginx + Let's Encrypt ──
#   1. Install certbot:  sudo apt install certbot python3-certbot-nginx
#   2. Get certificate:  sudo certbot --nginx -d alternative.ge -d www.alternative.ge
#   3. Auto-renew:       sudo certbot renew --dry-run
#   4. Nginx config should proxy_pass to http://localhost:3001
#      and set header X-Forwarded-Proto $scheme
#
# ── Docker / Kubernetes ──
#   Use an ingress controller (e.g., nginx-ingress, traefik) with
#   cert-manager for automatic Let's Encrypt certificates.
